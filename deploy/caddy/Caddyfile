# chip-leader · Caddy reverse proxy (OPTIONAL · LAN convenience only)
#
# For the public chip.ogrady.football URL, Caddy is no longer used —
# Cloudflare Tunnel handles TLS + auth. See deploy/cloudflared/SETUP.md.
#
# This file is kept around only for the LAN convenience case below.

# Pretty hostname on the LAN (http://chip.local) instead of
# http://macmini.local:8765. Requires a Bonjour/local DNS alias on the LAN.
# Skip this entirely unless you actually want it.
chip.local:80 {
    reverse_proxy localhost:8765
}
